AI_PROVIDER=groq

# Groq profile
GROQ_API_KEY=your_primary_groq_api_key_here
GROQ_API_KEYS=your_primary_groq_api_key_here,your_backup_groq_api_key_here
GROQ_MODEL_NAME=groq/compound-mini

# Gemini profile
GOOGLE_API_KEY=your_primary_google_api_key_here
GOOGLE_API_KEYS=your_primary_google_api_key_here,your_backup_google_api_key_here
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL_NAME=models/gemini-embedding-001

# Use a separate collection when switching embedding providers.
CHROMA_COLLECTION_NAME=
DEFAULT_TOP_K=4
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
